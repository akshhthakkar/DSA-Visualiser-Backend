{
  "name": "dsa-visualizer-backend",
  "version": "1.0.0",
  "description": "Backend for DSA Visualizer - University SaaS Platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:all": "npm run shared:build && npm run build",
    "start": "node dist/index.js",
    "start:prod": "npx prisma migrate deploy && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:deploy:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:deploy:down": "docker compose -f docker-compose.prod.yml down",
    "shared:build": "npm --prefix shared run build",
    "shared:typecheck": "npm --prefix shared run type-check"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/node": "^10.47.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.4",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^7.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^7.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
